generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  storeName    String
  createdAt    DateTime @default(now())

  products     Product[]
  orders       Order[]
  customers    Customer[]
  chatHistory  ChatHistory[]
}

model Product {
  id        String   @id @default(uuid())
  userId    String
  name      String
  category  String?
  price     Decimal
  stock     Int      @default(0)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model Customer {
  id        String   @id @default(uuid())
  userId    String
  name      String
  email     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
}

model Order {
  id         String   @id @default(uuid())
  userId     String
  productId  String
  customerId String
  quantity   Int
  revenue    Decimal
  orderDate  DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id])
  customer   Customer @relation(fields: [customerId], references: [id])
}

model ChatHistory {
  id        String   @id @default(uuid())
  userId    String
  question  String
  answer    String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}